{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://codexqb.local/schemas/apply-run-schema.json",
  "title": "CodexQB Apply Run Artifact Contract",
  "description": "Reference JSON Schema for CodexQB Step 4 apply-run artifacts. Runtime validation is implemented by scripts/apply_run.py; this file is the public packaged contract.",
  "type": "object",
  "anyOf": [
    { "$ref": "#/$defs/ApplyRun" },
    { "$ref": "#/$defs/Progress" },
    { "$ref": "#/$defs/DispatchPacket" },
    { "$ref": "#/$defs/AgentRun" },
    { "$ref": "#/$defs/FinalReview" },
    { "$ref": "#/$defs/Result" },
    { "$ref": "#/$defs/ImplementerReport" },
    { "$ref": "#/$defs/TaskReview" },
    { "$ref": "#/$defs/FixReport" }
  ],
  "$defs": {
    "NonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "Sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "IsoTimestamp": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"
    },
    "TaskId": {
      "type": "string",
      "pattern": "^AR-apply-[A-Za-z0-9_.-]+-T[0-9]{3}$"
    },
    "AgentId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_.:-]{3,160}$"
    },
    "ApplyMode": {
      "enum": ["direct", "external_superpowers", "no_action", "subagent_serial"]
    },
    "TaskState": {
      "enum": [
        "PREFLIGHT",
        "BRIEFED",
        "IMPLEMENTING",
        "IMPLEMENTED",
        "TASK_REVIEW",
        "SECURITY_REVIEW",
        "FIXING",
        "RE_REVIEW",
        "VERIFIED",
        "BLOCKED",
        "NEEDS_CONTEXT"
      ]
    },
    "DispatchRole": {
      "enum": ["fixer", "implementer", "security_reviewer", "task_reviewer"]
    },
    "AgentStatus": {
      "enum": ["completed", "failed", "spawned"]
    },
    "ValidationCommand": {
      "type": "object",
      "required": ["argv", "exit_code"],
      "properties": {
        "id": { "$ref": "#/$defs/NonEmptyString" },
        "argv": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/NonEmptyString" }
        },
        "cwd": { "type": "string" },
        "exit_code": { "type": "integer" },
        "expected_exit_code": { "type": "integer" },
        "timeout_seconds": { "type": "integer", "minimum": 1 },
        "network": { "enum": ["allow", "deny", "live", "local"] },
        "probe_tier": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": true
    },
    "AgentProfile": {
      "type": "object",
      "required": ["agent_type", "model_profile", "sandbox"],
      "properties": {
        "agent_type": { "enum": ["default", "explorer", "worker"] },
        "model_profile": { "enum": ["balanced", "fast", "inherit", "security_strong", "strong"] },
        "sandbox": { "enum": ["read-only", "workspace-write"] }
      },
      "additionalProperties": false
    },
    "SourceSnapshotItem": {
      "type": "object",
      "required": ["path", "sha256"],
      "properties": {
        "path": { "$ref": "#/$defs/NonEmptyString" },
        "sha256": { "$ref": "#/$defs/Sha256" },
        "value": { "type": "string" }
      },
      "additionalProperties": false
    },
    "WorkspaceBaseline": {
      "type": "object",
      "required": [
        "vcs",
        "branch",
        "base_commit",
        "git_status_porcelain_sha256",
        "staged_diff_sha256",
        "unstaged_diff_sha256",
        "untracked_inventory_sha256",
        "untracked_count",
        "workspace_file_inventory_sha256",
        "workspace_file_count"
      ],
      "properties": {
        "vcs": { "enum": ["git", "non_git"] },
        "branch": { "type": "string" },
        "base_commit": { "type": "string" },
        "git_status_porcelain_sha256": { "$ref": "#/$defs/Sha256" },
        "staged_diff_sha256": { "$ref": "#/$defs/Sha256" },
        "unstaged_diff_sha256": { "$ref": "#/$defs/Sha256" },
        "untracked_inventory_sha256": { "$ref": "#/$defs/Sha256" },
        "untracked_count": { "type": "integer", "minimum": 0 },
        "workspace_file_inventory_sha256": {
          "anyOf": [
            { "$ref": "#/$defs/Sha256" },
            { "const": "" }
          ]
        },
        "workspace_file_count": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "ReadyQueueItem": {
      "type": "object",
      "required": ["readiness_status", "subplan_path"],
      "properties": {
        "readiness_status": { "enum": ["READY", "READY_WITH_WARNINGS"] },
        "subplan_path": {
          "type": "string",
          "pattern": "^Planner-docs/Faz-[0-9]+-Plans/Faz[0-9]+\\.[0-9]+-[a-z0-9-]+\\.md$"
        }
      },
      "additionalProperties": false
    },
    "ApplyRun": {
      "type": "object",
      "required": [
        "apply_run_schema_version",
        "artifact_schema_version",
        "handoff_contract_version",
        "plugin_version",
        "apply_requested_mode",
        "apply_spec_id",
        "apply_spec_digest",
        "apply_spec_inputs",
        "apply_run_id",
        "apply_run_invocation_id",
        "mode",
        "workspace_baseline",
        "user_approval",
        "commit_policy",
        "push_allowed",
        "pr_allowed",
        "max_writer_agents",
        "max_subagent_depth",
        "agent_profiles",
        "source_snapshot",
        "source_snapshot_digest",
        "step4_readiness",
        "external_superpowers",
        "safety"
      ],
      "properties": {
        "apply_run_schema_version": { "const": 1 },
        "artifact_schema_version": { "const": 3 },
        "handoff_contract_version": { "const": 2 },
        "plugin_version": { "const": "0.3.0" },
        "apply_requested_mode": { "$ref": "#/$defs/ApplyMode" },
        "apply_spec_id": {
          "type": "string",
          "pattern": "^apply-spec-(direct|external_superpowers|no_action|subagent_serial)-[a-f0-9]{16}$"
        },
        "apply_spec_digest": { "$ref": "#/$defs/Sha256" },
        "apply_spec_inputs": {
          "type": "object",
          "required": ["ready_queue"],
          "properties": {
            "ready_queue": {
              "type": "array",
              "items": { "$ref": "#/$defs/ReadyQueueItem" }
            }
          },
          "additionalProperties": true
        },
        "apply_run_id": {
          "type": "string",
          "pattern": "^apply-(direct|external_superpowers|no_action|subagent_serial)-[a-f0-9]{12}-[A-Za-z0-9_.-]+$"
        },
        "apply_run_invocation_id": { "$ref": "#/$defs/NonEmptyString" },
        "mode": { "$ref": "#/$defs/ApplyMode" },
        "workspace_requested": { "type": "string" },
        "workspace_detected": { "type": "string" },
        "workspace_verified": { "type": "boolean" },
        "workspace_mode": { "enum": ["non_git_unsafe", "unverified_current_worktree"] },
        "user_approval": { "type": "boolean" },
        "workspace_baseline": { "$ref": "#/$defs/WorkspaceBaseline" },
        "commit_policy": { "const": "none" },
        "push_allowed": { "const": false },
        "pr_allowed": { "const": false },
        "max_writer_agents": { "const": 1 },
        "max_subagent_depth": { "const": 1 },
        "agent_profiles": {
          "type": "object",
          "required": [
            "controller",
            "explorer",
            "implementer",
            "task_reviewer",
            "security_reviewer",
            "fixer",
            "final_reviewer"
          ],
          "properties": {
            "controller": { "$ref": "#/$defs/AgentProfile" },
            "explorer": { "$ref": "#/$defs/AgentProfile" },
            "implementer": { "$ref": "#/$defs/AgentProfile" },
            "task_reviewer": { "$ref": "#/$defs/AgentProfile" },
            "security_reviewer": { "$ref": "#/$defs/AgentProfile" },
            "fixer": { "$ref": "#/$defs/AgentProfile" },
            "final_reviewer": { "$ref": "#/$defs/AgentProfile" }
          },
          "additionalProperties": false
        },
        "source_snapshot": {
          "type": "array",
          "items": { "$ref": "#/$defs/SourceSnapshotItem" }
        },
        "source_snapshot_digest": { "$ref": "#/$defs/Sha256" },
        "step4_readiness": {
          "type": "object",
          "required": [
            "audit_path",
            "audit_present",
            "ready_queue_count",
            "validator_command",
            "validator_status",
            "validator_output_sha256",
            "execution_queue_state",
            "execution_gate",
            "mode"
          ],
          "properties": {
            "audit_path": { "const": "Planner-docs/Sub-Planing-Audit.md" },
            "audit_present": { "type": "boolean" },
            "ready_queue_count": { "type": "integer", "minimum": 0 },
            "no_action_required": { "type": "boolean" },
            "validator_command": {
              "type": "array",
              "minItems": 1,
              "items": { "$ref": "#/$defs/NonEmptyString" }
            },
            "validator_status": { "type": "string" },
            "validator_output_sha256": { "$ref": "#/$defs/Sha256" },
            "execution_queue_state": { "enum": ["BLOCKED", "NO_ACTION_REQUIRED", "READY", "unknown"] },
            "execution_gate": { "const": "step4_validator_must_pass_before_product_changes" },
            "mode": { "$ref": "#/$defs/ApplyMode" }
          },
          "additionalProperties": true
        },
        "external_superpowers": {
          "type": "object",
          "required": ["required", "availability", "fallback_mode", "adapter_policy"],
          "properties": {
            "required": { "type": "boolean" },
            "availability": { "enum": ["available", "not_checked", "unavailable"] },
            "fallback_mode": { "const": "subagent_serial" },
            "adapter_policy": { "type": "string" },
            "reconciled_to": { "const": "subagent_serial" },
            "version": { "type": "string" },
            "source_path": { "type": "string" },
            "license_acknowledged": { "type": "boolean" }
          },
          "additionalProperties": true
        },
        "safety": {
          "type": "object",
          "required": [
            "executes_implementation",
            "allows_commit_push_pr_deploy",
            "one_writer_per_slice",
            "subagents_read_only_by_default"
          ],
          "properties": {
            "executes_implementation": { "const": false },
            "allows_commit_push_pr_deploy": { "const": false },
            "one_writer_per_slice": { "const": true },
            "subagents_read_only_by_default": { "const": true }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "Task": {
      "type": "object",
      "required": ["task_id", "state", "readiness_status", "writer_lock", "validation_commands", "dispatch", "agent_runs"],
      "properties": {
        "task_id": { "$ref": "#/$defs/TaskId" },
        "state": { "$ref": "#/$defs/TaskState" },
        "readiness_status": { "enum": ["READY", "READY_WITH_WARNINGS"] },
        "source_subplan_path": { "type": ["string", "null"] },
        "source_subplan_sha256": { "anyOf": [{ "$ref": "#/$defs/Sha256" }, { "type": "null" }] },
        "fresh_context_contract": { "type": "object" },
        "finding_ids": {
          "type": "array",
          "items": { "type": "string" }
        },
        "security_review_required": { "type": "boolean" },
        "writer_lock": {
          "anyOf": [{ "$ref": "#/$defs/WriterLock" }, { "type": "null" }]
        },
        "validation_commands": {
          "type": "array",
          "items": { "$ref": "#/$defs/ValidationCommand" }
        },
        "dispatch": {
          "anyOf": [{ "$ref": "#/$defs/DispatchState" }, { "type": "null" }]
        },
        "agent_runs": {
          "type": "array",
          "items": { "$ref": "#/$defs/AgentRun" }
        },
        "redispatch_count": { "type": "integer", "minimum": 0 },
        "brief_sha256": { "$ref": "#/$defs/Sha256" }
      },
      "additionalProperties": true
    },
    "WriterLock": {
      "type": "object",
      "required": ["lock_id", "task_id", "owner", "acquired_at", "expires_in_seconds"],
      "properties": {
        "lock_id": { "type": "string", "pattern": "^[a-f0-9]{16}$" },
        "task_id": { "$ref": "#/$defs/TaskId" },
        "owner": { "$ref": "#/$defs/NonEmptyString" },
        "acquired_at": { "$ref": "#/$defs/IsoTimestamp" },
        "expires_in_seconds": { "type": "number", "minimum": 0 }
      },
      "additionalProperties": true
    },
    "DispatchState": {
      "type": "object",
      "required": ["status", "role", "spawn_tool", "prompt_sha256", "packet_sha256", "attempt", "event_sequence"],
      "properties": {
        "status": { "enum": ["completed", "failed", "packet_ready", "spawned"] },
        "role": { "$ref": "#/$defs/DispatchRole" },
        "spawn_tool": { "const": "multi_agent_v1.spawn_agent" },
        "prompt_sha256": { "$ref": "#/$defs/Sha256" },
        "packet_sha256": { "$ref": "#/$defs/Sha256" },
        "attempt": { "type": "integer", "minimum": 1 },
        "event_sequence": { "type": "integer", "minimum": 1 },
        "agent_id": { "$ref": "#/$defs/AgentId" },
        "updated_at": { "$ref": "#/$defs/IsoTimestamp" },
        "summary": { "type": "string" },
        "failure_recoverable": { "type": "boolean" }
      },
      "additionalProperties": true
    },
    "Progress": {
      "type": "object",
      "required": [
        "apply_run_id",
        "mode",
        "tasks",
        "verified_task_ids",
        "active_writer_locks",
        "final_review_required",
        "final_review_complete",
        "resume_cursor",
        "events"
      ],
      "properties": {
        "apply_run_id": {
          "type": "string",
          "pattern": "^apply-(direct|external_superpowers|no_action|subagent_serial)-[a-f0-9]{12}-[A-Za-z0-9_.-]+$"
        },
        "mode": { "$ref": "#/$defs/ApplyMode" },
        "tasks": {
          "type": "array",
          "items": { "$ref": "#/$defs/Task" }
        },
        "verified_task_ids": {
          "type": "array",
          "items": { "$ref": "#/$defs/TaskId" }
        },
        "active_writer_locks": {
          "type": "array",
          "maxItems": 1,
          "items": { "$ref": "#/$defs/WriterLock" }
        },
        "final_review_required": { "type": "boolean" },
        "final_review_complete": { "type": "boolean" },
        "resume_cursor": {
          "anyOf": [
            {
              "type": "object",
              "required": ["task_id", "state", "event_sequence"],
              "properties": {
                "task_id": { "$ref": "#/$defs/TaskId" },
                "state": { "$ref": "#/$defs/TaskState" },
                "event_sequence": { "type": "integer", "minimum": 1 }
              },
              "additionalProperties": true
            },
            { "type": "null" }
          ]
        },
        "events": {
          "type": "array",
          "items": { "type": "object" }
        }
      },
      "additionalProperties": true
    },
    "DispatchPacket": {
      "type": "object",
      "required": [
        "dispatch_packet_schema_version",
        "task_id",
        "role",
        "attempt",
        "dispatch_status",
        "spawn_tool",
        "spawn_request",
        "model_profile",
        "model_override",
        "sandbox",
        "brief_sha256",
        "prompt_sha256",
        "run_relative_task_dir",
        "expected_report_paths",
        "prepared_by",
        "prepared_at"
      ],
      "properties": {
        "dispatch_packet_schema_version": { "const": 1 },
        "task_id": { "$ref": "#/$defs/TaskId" },
        "role": { "$ref": "#/$defs/DispatchRole" },
        "attempt": { "type": "integer", "minimum": 1 },
        "dispatch_status": { "const": "packet_ready" },
        "spawn_tool": { "const": "multi_agent_v1.spawn_agent" },
        "spawn_request": {
          "type": "object",
          "required": ["agent_type", "fork_context", "message"],
          "properties": {
            "agent_type": { "enum": ["default", "worker"] },
            "fork_context": { "const": false },
            "message": { "$ref": "#/$defs/NonEmptyString" }
          },
          "additionalProperties": false
        },
        "model_profile": { "enum": ["balanced", "security_strong", "strong"] },
        "model_override": { "type": "null" },
        "sandbox": { "enum": ["read-only", "workspace-write"] },
        "brief_sha256": { "$ref": "#/$defs/Sha256" },
        "prompt_sha256": { "$ref": "#/$defs/Sha256" },
        "run_relative_task_dir": { "$ref": "#/$defs/TaskId" },
        "expected_report_paths": {
          "type": "object",
          "required": ["implementer", "task_reviewer", "security_reviewer", "fixer"],
          "properties": {
            "implementer": { "const": "Implementer-Report.json" },
            "task_reviewer": { "const": "Task-Review.json" },
            "security_reviewer": { "const": "Task-Review.json" },
            "fixer": { "const": "Fix-Report.json" }
          },
          "additionalProperties": false
        },
        "prepared_by": { "$ref": "#/$defs/NonEmptyString" },
        "prepared_at": { "$ref": "#/$defs/IsoTimestamp" }
      },
      "additionalProperties": false
    },
    "AgentRun": {
      "type": "object",
      "required": ["task_id", "role", "attempt", "agent_id", "status", "packet_sha256", "prompt_sha256", "spawn_tool", "summary"],
      "properties": {
        "task_id": { "$ref": "#/$defs/TaskId" },
        "role": { "$ref": "#/$defs/DispatchRole" },
        "attempt": { "type": "integer", "minimum": 1 },
        "agent_id": { "$ref": "#/$defs/AgentId" },
        "status": { "$ref": "#/$defs/AgentStatus" },
        "packet_sha256": { "$ref": "#/$defs/Sha256" },
        "prompt_sha256": { "$ref": "#/$defs/Sha256" },
        "spawn_tool": { "const": "multi_agent_v1.spawn_agent" },
        "summary": { "type": "string" },
        "spawned_at": { "$ref": "#/$defs/IsoTimestamp" },
        "completed_at": { "$ref": "#/$defs/IsoTimestamp" },
        "failed_at": { "$ref": "#/$defs/IsoTimestamp" }
      },
      "additionalProperties": false
    },
    "ImplementerReport": {
      "type": "object",
      "required": ["status"],
      "properties": {
        "status": { "enum": ["BLOCKED", "DONE", "DONE_WITH_CONCERNS", "NEEDS_CONTEXT", "PENDING"] },
        "task_id": { "$ref": "#/$defs/TaskId" },
        "brief_sha256": { "$ref": "#/$defs/Sha256" },
        "implementer_agent_id": { "$ref": "#/$defs/AgentId" },
        "files_changed": {
          "type": "array",
          "items": { "type": "string" }
        },
        "validation_evidence": {
          "type": "array",
          "items": { "$ref": "#/$defs/ValidationCommand" }
        },
        "diff_sha256": { "$ref": "#/$defs/Sha256" },
        "controller_decision": { "type": "string" }
      },
      "additionalProperties": true
    },
    "TaskReview": {
      "type": "object",
      "properties": {
        "status": { "enum": ["PENDING"] },
        "task_id": { "$ref": "#/$defs/TaskId" },
        "brief_sha256": { "$ref": "#/$defs/Sha256" },
        "reviewer_agent_id": { "$ref": "#/$defs/AgentId" },
        "spec_compliance": { "enum": ["cannot_verify", "fail", "pass", "PENDING"] },
        "task_quality": { "enum": ["approved", "needs_fixes", "PENDING"] },
        "security_review": { "enum": ["fail", "not_required", "pass", "PENDING"] },
        "blocking_findings": {
          "type": "array",
          "items": { "type": "string" }
        },
        "fixes_required": {
          "type": "array",
          "items": { "type": "string" }
        },
        "evidence": {
          "type": "array",
          "items": { "type": "string" }
        },
        "re_review_required": { "type": "boolean" }
      },
      "additionalProperties": true
    },
    "FixReport": {
      "type": "object",
      "properties": {
        "status": { "enum": ["PENDING"] },
        "fixes": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": true
    },
    "FinalReview": {
      "type": "object",
      "required": ["status"],
      "properties": {
        "status": { "enum": ["not_required", "not_started", "pass"] },
        "reviewed_task_ids": {
          "type": "array",
          "items": { "$ref": "#/$defs/TaskId" }
        },
        "global_validations": {
          "type": "array",
          "items": { "$ref": "#/$defs/ValidationCommand" }
        },
        "evidence": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": true
    },
    "Result": {
      "type": "object",
      "required": ["apply_run_id", "status", "completed_tasks", "blocked_tasks", "next_action"],
      "properties": {
        "apply_run_id": {
          "type": "string",
          "pattern": "^apply-(direct|external_superpowers|no_action|subagent_serial)-[a-f0-9]{12}-[A-Za-z0-9_.-]+$"
        },
        "status": { "enum": ["complete", "initialized", "no_action"] },
        "completed_tasks": {
          "type": "array",
          "items": { "$ref": "#/$defs/TaskId" }
        },
        "blocked_tasks": {
          "type": "array",
          "items": { "$ref": "#/$defs/TaskId" }
        },
        "finalized_at": { "$ref": "#/$defs/IsoTimestamp" },
        "finalized_by": { "type": "string" },
        "event_sequence": { "type": "integer", "minimum": 1 },
        "next_action": { "type": "string" }
      },
      "additionalProperties": true
    }
  }
}
